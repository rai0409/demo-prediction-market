DEMO_PREDICTION_LIVE=0
DEMO_PREDICTION_POLL_SECONDS=30
DEMO_PREDICTION_LIMIT=50
DEMO_PREDICTION_DB=data/demo_prediction.sqlite3
DEMO_PREDICTION_AUTO_REFRESH=0
DEMO_PREDICTION_REFRESH_SECONDS=60
DEMO_PREDICTION_QUICK_REFRESH_SECONDS=5
DEMO_PREDICTION_DETAIL_REFRESH_SECONDS=3
DEMO_PREDICTION_WS_ENABLED=0
DEMO_PREDICTION_WS_TOP_N=10
DEMO_PREDICTION_WS_STALE_SECONDS=90
DEMO_PREDICTION_MAX_DEMO_STAKE=10000
DEMO_COOKIE_SECURE=0

# Set a strong random value before enabling internal operations.
# Demo points are non-cash, non-transferable, and non-exchangeable.
DEMO_ADMIN_TOKEN=

# Participant identity security
# Public/product defaults: participant switching and header overrides are disabled.
DEMO_STRICT_PARTICIPANT_ACCESS=1
DEMO_PARTICIPANT_SWITCH_ENABLED=0
DEMO_ALLOW_USER_HEADER=0

# Stored translation cache. The product default does not run translations.
DEMO_TRANSLATION_ENABLED=0
DEMO_TRANSLATION_PROVIDER=noop
DEMO_TRANSLATION_TARGET_LANGUAGE=ja
DEMO_TRANSLATION_MAX_CHARS=4000
DEMO_TRANSLATION_MODEL=Helsinki-NLP/opus-mt-en-jap
DEMO_TRANSLATION_DEVICE=auto
DEMO_TRANSLATION_BATCH_SIZE=4
DEMO_TRANSLATION_LOCAL_FILES_ONLY=0

# Optional Azure Translator REST provider. Leave the key blank in checked-in files.
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_REGION=
AZURE_TRANSLATOR_API_VERSION=3.0
AZURE_TRANSLATOR_SOURCE_LANGUAGE=en
AZURE_TRANSLATOR_TARGET_LANGUAGE=ja
AZURE_TRANSLATOR_TIMEOUT_SECONDS=15
AZURE_TRANSLATOR_MAX_RETRIES=3
AZURE_TRANSLATOR_BATCH_SIZE=20

# Comma-separated allowlist for controlled demo environments.
# Replace this example before deployment; do not commit real/private codes.
DEMO_PARTICIPANT_CODES=demo-participant-001
